import asyncio
import os
import sys
import time
from datetime import datetime
import aiohttp
import requests
from google.colab import drive
from bip_utils import (
    Bip39MnemonicGenerator, 
    Bip39SeedGenerator, 
    Bip44, 
    Bip44Coins, 
    Bip44Changes, 
    Bip39WordsNum
)
from colorthon import Colors

drive.mount('/content/drive')

SAVE_PATH = "/content/drive/MyDrive/found_wallets"
if not os.path.exists(SAVE_PATH):
    os.makedirs(SAVE_PATH)

RED = Colors.RED
GREEN = Colors.GREEN
CYAN = Colors.CYAN
YELLOW = Colors.YELLOW
WHITE = Colors.WHITE
RESET = Colors.RESET

def save_found_wallet(network, address, balance, mnemonic, seed_hex):
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    filename = f"{SAVE_PATH}/balance_found_{network}_{timestamp}.txt"

    with open(filename, "w") as file:
        file.write(f"--- {network} Wallet Found ---\n")
        file.write(f"Mnemonic Phrase: {mnemonic}\n")
        file.write(f"Seed Hex: {seed_hex}\n")
        file.write(f"Address: {address}\n")
        file.write(f"Balance: {balance} {network}\n")
        file.write(f"Found At: {datetime.now()}\n")

    print(f"\n{GREEN}(!) {network} Wallet with balance saved to Drive: {filename}{RESET}\n")

def generate_addresses(seed_bytes: bytes) -> tuple:
    btc_ctx = Bip44.FromSeed(seed_bytes, Bip44Coins.BITCOIN)
    btc_addr = btc_ctx.Purpose().Coin().Account(0).Change(Bip44Changes.CHAIN_EXT).AddressIndex(0).PublicKey().ToAddress()

    eth_ctx = Bip44.FromSeed(seed_bytes, Bip44Coins.ETHEREUM)
    eth_addr = eth_ctx.Purpose().Coin().Account(0).Change(Bip44Changes.CHAIN_EXT).AddressIndex(0).PublicKey().ToAddress()

    doge_ctx = Bip44.FromSeed(seed_bytes, Bip44Coins.DOGECOIN)
    doge_addr = doge_ctx.Purpose().Coin().Account(0).Change(Bip44Changes.CHAIN_EXT).AddressIndex(0).PublicKey().ToAddress()

    return btc_addr, eth_addr, doge_addr

async def get_balance_async(session: aiohttp.ClientSession, address: str, network: str) -> str:
    urls = {
        "btc": f"https://blockchain.info/balance?active={address}",
        "eth": f"https://ethbook.guarda.co/api/v2/address/{address}",
        "bnb": f"https://bsc-nn.atomicwallet.io/api/v2/address/{address}",
        "doge": f"https://dogecoin.atomicwallet.io/api/v2/address/{address}"
    }
    
    url = urls.get(network)
    try:
        async with session.get(url, timeout=10) as response:
            if response.status == 200:
                data = await response.json()
                if network == "btc":
                    return str(data.get(address, {}).get("final_balance", "0"))
                return str(data.get("balance", "0"))
            elif response.status == 429:
                await asyncio.sleep(2)
                return await get_balance_async(session, address, network)
    except Exception:
        return "0"
    return "0"

total_generated = 0
total_found = 0
script_start_time = time.time()

async def main():
    global total_generated, total_found
    
    connector = aiohttp.TCPConnector(limit=50)
    async with aiohttp.ClientSession(connector=connector) as session:
        batch_size = 20 
        
        while True:
            batch_data = []
            for _ in range(batch_size):
                total_generated += 1
                mnemonic = Bip39MnemonicGenerator().FromWordsNumber(Bip39WordsNum.WORDS_NUM_12)
                seed_bytes = Bip39SeedGenerator(mnemonic).Generate()
                seed_hex = seed_bytes.hex()
                btc_addr, eth_addr, doge_addr = generate_addresses(seed_bytes)
                
                batch_data.append({
                    "mnemonic": mnemonic,
                    "seed_hex": seed_hex,
                    "btc": btc_addr,
                    "eth": eth_addr,
                    "doge": doge_addr
                })

            tasks = []
            for wallet in batch_data:
                tasks.append(get_balance_async(session, wallet["btc"], "btc"))
                tasks.append(get_balance_async(session, wallet["eth"], "eth"))
                tasks.append(get_balance_async(session, wallet["eth"], "bnb"))
                tasks.append(get_balance_async(session, wallet["doge"], "doge"))

            results = await asyncio.gather(*tasks)

            res_idx = 0
            for wallet in batch_data:
                btc_bal = int(results[res_idx]) / 10**8
                eth_bal = int(results[res_idx+1]) / 10**18
                bnb_bal = int(results[res_idx+2]) / 10**18
                doge_bal = int(results[res_idx+3]) / 10**8
                res_idx += 4

                if btc_bal > 0:
                    total_found += 1
                    save_found_wallet("BTC", wallet["btc"], btc_bal, wallet["mnemonic"], wallet["seed_hex"])
                if eth_bal > 0:
                    total_found += 1
                    save_found_wallet("ETH", wallet["eth"], eth_bal, wallet["mnemonic"], wallet["seed_hex"])
                if bnb_bal > 0:
                    total_found += 1
                    save_found_wallet("BNB", wallet["eth"], bnb_bal, wallet["mnemonic"], wallet["seed_hex"])
                if doge_bal > 0:
                    total_found += 1
                    save_found_wallet("DOGE", wallet["doge"], doge_bal, wallet["mnemonic"], wallet["seed_hex"])
                
                if total_generated % batch_size == 0:
                    elapsed = time.time() - script_start_time
                    rps = total_generated / elapsed if elapsed > 0 else 0
                    print(f"\rGenerated: {total_generated} | Found: {total_found} | RPS: {rps:.2f}", end="")

try:
    await main()
except KeyboardInterrupt:
    print(f"\nStopped. Total Scanned: {total_generated}")
